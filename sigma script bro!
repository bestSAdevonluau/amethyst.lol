RunService.RenderStepped:Connect(function()
	if Options.CamlockOn.Value and camlockTargetName then
		local targetPlayer = Players:FindFirstChild(camlockTargetName)
		if targetPlayer and targetPlayer.Character then
			local bone = targetPlayer.Character:FindFirstChild(Options.CamlockBone.Value)
			if bone and bone:IsA("BasePart") then
				local targetPosition = bone.Position
				if Options.CamlockPredOn.Value then
					targetPosition = targetPosition + (bone.Velocity * Options.CamlockPred.Value)
				end
				local newCFrame = CFrame.new(camera.CFrame.Position, targetPosition)
				if Options.CamlockSmooth.Value then
					camera.CFrame = camera.CFrame:Lerp(newCFrame, Options.CamlockLerp.Value)
				else
					camera.CFrame = newCFrame
				end
			end
		end
	end
end)

RunService.Heartbeat:Connect(function(deltaTime)
	if not player.Character then return end
	local root = player.Character:FindFirstChild("HumanoidRootPart")
	local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
	if not root or not humanoid then return end

	if FlyOn then
		humanoid.PlatformStand = true
		local flyDirection = Vector3.new(0, 0, 0)
		if UserInputService:IsKeyDown(Enum.KeyCode.W) then flyDirection = flyDirection + camera.CFrame.LookVector end
		if UserInputService:IsKeyDown(Enum.KeyCode.S) then flyDirection = flyDirection - camera.CFrame.LookVector end
		if UserInputService:IsKeyDown(Enum.KeyCode.A) then flyDirection = flyDirection - camera.CFrame.RightVector end
		if UserInputService:IsKeyDown(Enum.KeyCode.D) then flyDirection = flyDirection + camera.CFrame.RightVector end
		if flyDirection.Magnitude > 0 then
			root.CFrame = root.CFrame + (flyDirection.Unit * Options.CFlySpeedVal.Value * deltaTime)
		end
		root.Velocity = Vector3.new(0, 0, 0)
	else
		if humanoid.PlatformStand then
			humanoid.PlatformStand = false
		end
	end

	if SpeedOn and not FlyOn then
		if humanoid.MoveDirection.Magnitude > 0 then
			root.CFrame = root.CFrame + (humanoid.MoveDirection * Options.CFrameSpeedVal.Value * deltaTime)
		end
	end
end)

task.spawn(function()
	local CHAR_PARENT = GetCharParent()
	while true do
		task.wait(0.1)
		if getgenv().HBE and CHAR_PARENT then
			for _, playerEnemy in ipairs(Players:GetPlayers()) do
				if playerEnemy ~= player then
					local char = CHAR_PARENT:FindFirstChild(playerEnemy.Name)
					if char and char:FindFirstChild("HumanoidRootPart") then
						local hrp = char.HumanoidRootPart
						hrp.Size = HITBOX_SIZE
						hrp.Transparency = 0.7
						hrp.Color = Color3.fromRGB(160, 32, 240) 
						hrp.Material = Enum.Material.Neon
						hrp.CanCollide = false
					end
				end
			end
		else
			for _, playerEnemy in ipairs(Players:GetPlayers()) do
				if playerEnemy ~= player then
					local char = CHAR_PARENT and CHAR_PARENT:FindFirstChild(playerEnemy.Name)
					if char and char:FindFirstChild("HumanoidRootPart") then
						local hrp = char.HumanoidRootPart
						hrp.Size = Vector3.new(2, 2, 1)
						hrp.Transparency = 1
						hrp.CanCollide = true
					end
				end
			end
		end
		if Library.Unloaded then break end
	end
end)

