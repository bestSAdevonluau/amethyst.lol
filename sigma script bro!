-- Lógica asíncrona dedicada a manipular el tamaño de las Hitboxes en ejecución de fondo
task.spawn(function()
    local CHAR_PARENT = GetCharParent()
    while true do
        task.wait(0.1)
        if getgenv().HBE and CHAR_PARENT then
            for _, playerEnemy in ipairs(Players:GetPlayers()) do
                if playerEnemy ~= player then
                    local char = CHAR_PARENT:FindFirstChild(playerEnemy.Name)
                    if char and char:FindFirstChild("HumanoidRootPart") then
                        local hrp = char.HumanoidRootPart
                        hrp.Size = HITBOX_SIZE
                        hrp.Transparency = 0.7
                        hrp.Color = Color3.fromRGB(160, 32, 240) -- Color unificado Morado Amethyst
                        hrp.Material = Enum.Material.Neon
                        hrp.CanCollide = false
                    end
                end
            end
        else
            -- Si se apaga, revierte las hitboxes a su tamaño natural
            for _, playerEnemy in ipairs(Players:GetPlayers()) do
                if playerEnemy ~= player then
                    local char = CHAR_PARENT and CHAR_PARENT:FindFirstChild(playerEnemy.Name)
                    if char and char:FindFirstChild("HumanoidRootPart") then
                        local hrp = char.HumanoidRootPart
                        hrp.Size = Vector3.new(2, 2, 1)
                        hrp.Transparency = 1
                        hrp.CanCollide = true
                    end
                end
            end
        end
        if Library.Unloaded then break end
    end
end)

