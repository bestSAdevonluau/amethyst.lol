-- Lógica para buscar el objetivo más cercano que se encuentre dentro del FOV
local function getClosestPlayerInFOV()
    local closestPlayer = nil
    local shortestDistance = FovCircle.Radius
    
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local pos, onScreen = camera:WorldToViewportPoint(p.Character.HumanoidRootPart.Position)
            if onScreen then
                local mousePos = player:GetMouse()
                local distance = (Vector2.new(pos.X, pos.Y) - Vector2.new(mousePos.X, mousePos.Y)).Magnitude
                if distance < shortestDistance then
                    closestPlayer = p
                    shortestDistance = distance
                end
            end
        end
    end
    return closestPlayer
end

-- Listener del Keybind para activar/desactivar en PC o pantallas móviles
CamlockKeybind:OnClick(function()
    CamlockToggle:SetValue(not Options.CamlockOn.Value)
end)

CamlockToggle:OnChanged(function(val)
    if val then
        local target = getClosestPlayerInFOV()
        camlockTargetName = target and target.Name or nil
        if not camlockTargetName then
            CamlockToggle:SetValue(false) -- Apaga si no hay nadie en el FOV
        end
    else
        camlockTargetName = nil
    end
end)

-- Actualizaciones visuales y de estado del FOV en tiempo real
RunService.RenderStepped:Connect(function()
    local mousePos = player:GetMouse()
    FovCircle.Position = Vector2.new(mousePos.X, mousePos.Y)
    FovCircle.Visible = Options.FovVisible.Value
    FovCircle.Radius = Options.FovRadius.Value
    FovCircle.Color = Options.FovColor.Value
end)

-- Loop principal del apuntado (RenderStepped)
RunService.RenderStepped:Connect(function()
    if Options.CamlockOn.Value and camlockTargetName then
        local targetPlayer = Players:FindFirstChild(camlockTargetName)
        if targetPlayer and targetPlayer.Character then
            local humanoid = targetPlayer.Character:FindFirstChildOfClass("Humanoid")
            if humanoid and humanoid.Health > 0 then
                local bone = targetPlayer.Character:FindFirstChild(Options.CamlockBone.Value)
                if bone and bone:IsA("BasePart") then
                    local targetPosition = bone.Position
                    if Options.CamlockPredOn.Value then
                        targetPosition = targetPosition + (bone.Velocity * Options.CamlockPred.Value)
                    end
                    local newCFrame = CFrame.new(camera.CFrame.Position, targetPosition)
                    if Options.CamlockSmooth.Value then
                        camera.CFrame = camera.CFrame:Lerp(newCFrame, Options.CamlockLerp.Value)
                    else
                        camera.CFrame = newCFrame
                    end
                end
            else
                CamlockToggle:SetValue(false)
            end
        else
            CamlockToggle:SetValue(false)
        end
    end
end)

