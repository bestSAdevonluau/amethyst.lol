local function getClosestPlayerInFOV()
	local closestPlayer = nil
	local shortestDistance = FovCircle.Radius
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
			local pos, onScreen = camera:WorldToViewportPoint(p.Character.HumanoidRootPart.Position)
			if onScreen then
				local originPos
				if Options.MoveFov.Value then
					local mousePos = player:GetMouse()
					originPos = Vector2.new(mousePos.X, mousePos.Y)
				else
					originPos = camera.ViewportSize / 2
				end
				local distance = (Vector2.new(pos.X, pos.Y) - originPos).Magnitude
				if distance < shortestDistance then
					closestPlayer = p
					shortestDistance = distance
				end
			end
		end
	end
	return closestPlayer
end

